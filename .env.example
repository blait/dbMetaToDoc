# Copy to .env and fill in.  .env is gitignored.

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
# Bedrock inference profile for Claude Opus 4.8 (base model is not on-demand callable)
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8
# Bedrock embedding model used for description similarity scoring
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Target database (AWS RDS PostgreSQL) ---
PGHOST=your-instance.xxxxxxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=omop
PGUSER=omop_admin
PGPASSWORD=change-me
# CDM schema that holds the OMOP tables
PGSCHEMA=cdm

# --- OMOP version (data + ddl + truth must match) ---
OMOP_VERSION=5.3
